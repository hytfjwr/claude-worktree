{
  "name": "claude-worktree",
  "version": "1.0.0",
  "description": "CLI for parallel development with WezTerm + git worktree + Claude Code",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "claude-worktree": "bin/claude-worktree.ts"
  },
  "files": [
    "src",
    "bin"
  ],
  "scripts": {
    "dev": "bun run bin/claude-worktree.ts",
    "typecheck": "bun x tsc --noEmit",
    "lint": "biome check src bin",
    "lint:fix": "biome check --write src bin",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/bun": "latest"
  },
  "keywords": [
    "claude",
    "worktree",
    "wezterm",
    "cli",
    "parallel-development"
  ],
  "license": "MIT"
}
