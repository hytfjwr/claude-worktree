{
  "name": "claude-worktree",
  "version": "1.0.0",
  "description": "CLI for parallel development with WezTerm + git worktree + Claude Code",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "claude-worktree": "bin/claude-worktree.ts"
  },
  "files": [
    "src",
    "bin"
  ],
  "scripts": {
    "dev": "bun run bin/claude-worktree.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "bun x tsc --noEmit",
    "lint": "biome check src bin",
    "lint:fix": "biome check --write src bin",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/bun": "latest",
    "@types/node": "^22",
    "typescript": "^5.8",
    "vitest": "^3"
  },
  "keywords": [
    "claude",
    "worktree",
    "wezterm",
    "cli",
    "parallel-development"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.29.1"
}
