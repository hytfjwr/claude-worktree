{
  "name": "claude-worktree",
  "version": "1.0.0",
  "description": "WezTerm + git worktree + Claude Code で並列開発するCLI",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "claude-worktree": "bin/claude-worktree.ts"
