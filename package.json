{
  "name": "@hytfjwr/claude-worktree",
  "version": "0.11.0",
  "description": "CLI for parallel development with git worktree + Claude Code",
  "type": "module",
  "bin": {
    "claude-worktree": "dist/bin/claude-worktree.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "dev": "node scripts/build.mjs && node dist/bin/claude-worktree.js",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src bin",
    "lint:fix": "biome check --write src bin",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/node": "^25",
    "@vitest/coverage-v8": "^3",
    "esbuild": "^0.28.0",
    "lefthook": "^2",
    "typescript": "^6.0",
    "vitest": "^3"
  },
  "keywords": [
    "claude",
    "claude-code",
    "worktree",
    "git-worktree",
    "wezterm",
    "tmux",
    "cli",
    "parallel-development",
    "ai-development"
  ],
  "author": "hytfjwr",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.29.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "minimatch": ">=10.2.5",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2",
      "postcss@<8.5.10": ">=8.5.10"
    }
  }
}
